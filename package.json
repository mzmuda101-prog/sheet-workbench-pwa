{
  "name": "sheet-workbench-pwa",
  "version": "1.0.0",
  "description": "Local, offline-first workbook workbench for exploring, filtering, restructuring, and lightly editing Excel files in the browser.",
  "private": true,
  "scripts": {
    "serve": "python3 -m http.server 7821",
    "check:i18n": "node scripts/check-i18n.js",
    "test": "node scripts/check-i18n.js && node scripts/smoke-playwright.js && node scripts/save-stress-playwright.js && node scripts/save-roundtrip-playwright.js && node scripts/monthly-summary-playwright.js && node scripts/export-playwright.js && node scripts/validation-playwright.js && node scripts/derived-columns-playwright.js",
    "test:export": "node scripts/export-playwright.js",
    "test:validation": "node scripts/validation-playwright.js",
    "test:derived": "node scripts/derived-columns-playwright.js",
    "test:save": "node scripts/save-stress-playwright.js && node scripts/save-roundtrip-playwright.js",
    "test:roundtrip": "node scripts/save-roundtrip-playwright.js",
    "test:monthly": "node scripts/monthly-summary-playwright.js",
    "test:stress": "node scripts/test-runner.mjs",
    "test:stress:file": "node scripts/test-runner.mjs",
    "gen:stress": "node scripts/gen-stress-test.js",
    "release": "node scripts/bump-version.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mzmuda101-prog/excel-workbench-pwa.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mzmuda101-prog/excel-workbench-pwa/issues"
  },
  "homepage": "https://github.com/mzmuda101-prog/excel-workbench-pwa#readme",
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
